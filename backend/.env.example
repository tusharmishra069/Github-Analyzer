# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Strong random secret for API key signing.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=replace_with_64_hex_chars_generated_secret

# ── Optional ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
APP_ENV=production

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Override LLM model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Railway/low-memory tuning (optional)
# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
# EMBEDDING_BATCH_SIZE=16
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=100
# RETRIEVAL_QUERY_COUNT=4
# RETRIEVAL_K_PER_QUERY=4
# LLM_MAX_TOKENS=1400
# MAX_EMBED_BYTES=2097152

# Override parser limits (defaults shown)
# MAX_FILE_COUNT=60
# MAX_FILE_SIZE_BYTES=262144
